{
  "name": "recurkit",
  "version": "1.0.0",
  "description": "Dead simple recurring task manager for solo operators",
  "main": "index.html",
  "scripts": {
    "serve": "npx http-server . -p 8080 -o",
    "build:web": "node build-www.js",
    "cap:sync": "npm run build:web && npx cap sync",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "build:android": "npm run cap:sync && npx cap open android",
    "build:ios": "npm run cap:sync && npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}
